// ══════════════════════════════════════
// ORIENTATION
// ══════════════════════════════════════
async function unlockOrientation(){
  try{
    if(screen.orientation&&screen.orientation.unlock)await screen.orientation.unlock();
    if(screen.unlockOrientation)screen.unlockOrientation();
  }catch{}
}
function checkOrientation(){
  document.getElementById('app').classList.toggle('land',window.innerWidth>window.innerHeight);
}
window.addEventListener('orientationchange',()=>setTimeout(checkOrientation,200));
window.addEventListener('resize',checkOrientation);
unlockOrientation(); checkOrientation();

// ══════════════════════════════════════
// WAKE LOCK & SW
// ══════════════════════════════════════
async function wakeLock(){try{if('wakeLock'in navigator)await navigator.wakeLock.request('screen');}catch{}}
wakeLock();
if('serviceWorker'in navigator){
  navigator.serviceWorker.register('./sw.js').catch(()=>{});
  navigator.serviceWorker.addEventListener('message',e=>{if(e.data?.type==='POINT')addPoint(e.data.team);});
}

// URL params
const _p=new URLSearchParams(location.search).get('punto');
if(_p==='1'||_p==='2'){history.replaceState({},'',location.pathname);setTimeout(()=>addPoint(parseInt(_p)),300);}

// Keyboard
document.addEventListener('keydown',e=>{
  if(e.key==='1')addPoint(1);
  if(e.key==='2')addPoint(2);
  if(e.key==='z'||e.key==='Z')undoPoint();
  if(e.key==='Escape')document.querySelectorAll('.panel.show').forEach(el=>el.classList.remove('show'));
});


// ══════════════════════════════════════
// FORCE LANDSCAPE ORIENTATION
// ══════════════════════════════════════
async function lockLandscape(){
  try{
    if(screen.orientation && screen.orientation.lock){
      await screen.orientation.lock('landscape');
      console.log('Locked to landscape');
      return;
    }
  }catch(e){ console.log('Lock failed, using CSS rotation:', e); }
  // Fallback: CSS rotation handles it (already in stylesheet)
}
lockLandscape();


// ══════════════════════════════════════
// PERSISTENCE — save/restore match state
// ══════════════════════════════════════
const SAVE_KEY = 'ps_match_v1';

function saveMatch(){
  if(S.over) return; // don't save finished matches
  try{
    localStorage.setItem(SAVE_KEY, JSON.stringify({
      S:          S,
      elapsed:    elapsed,
      setStart:   setStartElapsed,
      server:     server,
      activeTeam: activeTeam,
      savedAt:    Date.now()
    }));
  }catch(e){}
}

function clearSavedMatch(){
  try{ localStorage.removeItem(SAVE_KEY); }catch{}
}

function hasSavedMatch(){
  try{
    const raw = localStorage.getItem(SAVE_KEY);
    if(!raw) return false;
    const d = JSON.parse(raw);
    // only restore if saved less than 24h ago and has some activity
    const age = Date.now() - (d.savedAt||0);
    return age < 86400000 && d.S && (d.S.sets[0]+d.S.sets[1]+d.S.games[0]+d.S.games[1]+d.S.pts[0]+d.S.pts[1]) > 0;
  }catch{ return false; }
}

function restoreMatch(){
  try{
    const d = JSON.parse(localStorage.getItem(SAVE_KEY));
    S           = d.S;
    elapsed     = d.elapsed    || 0;
    setStartElapsed = d.setStart || 0;
    server      = d.server     || 0;
    activeTeam  = d.activeTeam || 1;
    // Restart timer from where we left off
    if(elapsed > 0){
      timerStart = Date.now() - elapsed*1000;
      timerRef = setInterval(()=>{
        elapsed = Math.floor((Date.now()-timerStart)/1000);
        const el = document.getElementById('timer');
        el.textContent = fmt(elapsed);
        el.classList.add('on');
      },1000);
    }
    render();
    showToast('Partida restaurada ✓', 0);
  }catch(e){
    console.error('Restore failed:', e);
    showToast('Error al restaurar', 0);
  }
}

// Resume dialog
function showResumeDialog(){
  try{
    const d = JSON.parse(localStorage.getItem(SAVE_KEY));
    const s = d.S;
    const age = Math.round((Date.now()-(d.savedAt||0))/60000);
    const info = document.getElementById('resume-info');
    if(info){
      info.innerHTML =
        `<b style="color:#0f172a">${s.names[0]}</b> vs <b style="color:#0f172a">${s.names[1]}</b><br>`+
        `Sets: ${s.sets[0]} – ${s.sets[1]}<br>`+
        `Juegos: ${s.games[0]} – ${s.games[1]}<br>`+
        `Hace ${age<1?'menos de 1 min':age+' min'}`;
    }
  }catch{}
  document.getElementById('resume-dialog').classList.add('show');
}
function resumeYes(){
  document.getElementById('resume-dialog').classList.remove('show');
  restoreMatch();
}
function resumeNo(){
  document.getElementById('resume-dialog').classList.remove('show');
  clearSavedMatch();
  setTimeout(showServeModal, 300);
}

// ══════════════════════════════════════
// INIT
// ══════════════════════════════════════
loadCfg();
initVoice();
render();
loadNtfyChannel();
// Check for saved match
if(hasSavedMatch()){
  setTimeout(showResumeDialog, 400);
} else {
  setTimeout(showServeModal, 600);
}
</script>
